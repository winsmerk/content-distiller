{
  "_comment": "抖音（Douyin）TikHub 端点池配置 — 每个 pool 至少 1 条有效链路。v1.1 实测更新：废弃路径已移除，search_users 改用 creator API。",
  "platform": "douyin",
  "version": "1.1",
  "last_updated": "2026-05-06",
  "_priority_note": "v1.1 已实测可用性。search_users: creator endpoint（返回数字uid，调用方需换取sec_uid）。fetch_user_info: 仅 app v3 handler_user_profile 可用。",

  "pools": {

    "search_users": [
      {
        "group": "search_v2",
        "path": "/api/v1/douyin/search/fetch_user_search_v2",
        "method": "POST",
        "params": {"keyword": "${keyword}", "cursor": "${cursor}"},
        "adapter": "dy_search_users_search_v2",
        "_note": "Douyin-Search-API v2，直接返回 sec_uid，参数最简"
      },
      {
        "group": "search_v1",
        "path": "/api/v1/douyin/search/fetch_user_search",
        "method": "POST",
        "params": {"keyword": "${keyword}", "cursor": "${cursor}", "douyin_user_fans": "", "douyin_user_type": "", "search_id": ""},
        "adapter": "dy_search_users_search_v1",
        "_note": "Douyin-Search-API v1，直接返回 sec_uid，支持粉丝数筛选"
      },
      {
        "group": "creator",
        "path": "/api/v1/douyin/creator/fetch_user_search",
        "method": "GET",
        "params": {"user_name": "${keyword}", "cursor": "${cursor}", "count": "${count}"},
        "adapter": "dy_search_users_creator",
        "_note": "末位兜底。返回数字 uid，调用方需调 fetch_user_profile_by_uid 换取 sec_uid"
      }
    ],

    "search_videos": [
      {
        "group": "app",
        "path": "/api/v1/douyin/app/v3/fetch_search_result",
        "method": "GET",
        "params": {"keyword": "${keyword}", "offset": "${offset}", "count": 20, "search_type": "video"},
        "adapter": "dy_search_videos_app",
        "_note": "v1.0 首选，app v3 通用搜索接口"
      },
      {
        "group": "web",
        "path": "/api/v1/douyin/web/fetch_search_result",
        "method": "GET",
        "params": {"keyword": "${keyword}", "offset": "${offset}", "count": 20},
        "adapter": "dy_search_videos_web",
        "_note": "v1.0 备选，web 端搜索接口"
      },
      {
        "group": "app_v2",
        "path": "/api/v1/douyin/app/v2/search_videos",
        "method": "GET",
        "params": {"keyword": "${keyword}", "page": "${page}"},
        "adapter": "dy_search_videos_app_v2",
        "_note": "v1.0 末位兜底"
      }
    ],

    "fetch_user_info": [
      {
        "group": "app",
        "path": "/api/v1/douyin/app/v3/handler_user_profile",
        "method": "GET",
        "params": {"sec_user_id": "${user_id}"},
        "adapter": "dy_user_info_app",
        "_note": "首选"
      },
      {
        "group": "web",
        "path": "/api/v1/douyin/web/handler_user_profile",
        "method": "GET",
        "params": {"sec_user_id": "${user_id}"},
        "adapter": "dy_user_info_web",
        "_note": "备用"
      }
    ],

    "fetch_user_videos": [
      {
        "group": "app",
        "path": "/api/v1/douyin/app/v3/fetch_user_post_videos",
        "method": "GET",
        "params": {"sec_user_id": "${user_id}", "max_cursor": "${cursor}", "count": 20},
        "adapter": "dy_user_videos_app",
        "_note": "v1.0 首选，游标分页"
      },
      {
        "group": "web",
        "path": "/api/v1/douyin/web/fetch_user_post_videos",
        "method": "GET",
        "params": {"sec_uid": "${user_id}", "max_cursor": "${cursor}", "count": 20},
        "adapter": "dy_user_videos_web",
        "_note": "v1.0 备选"
      },
      {
        "group": "app_v2",
        "path": "/api/v1/douyin/app/v2/fetch_user_post",
        "method": "GET",
        "params": {"sec_user_id": "${user_id}", "max_cursor": "${cursor}"},
        "adapter": "dy_user_videos_app_v2",
        "_note": "v1.0 末位兜底"
      }
    ],

    "fetch_video_detail": [
      {
        "group": "app",
        "path": "/api/v1/douyin/app/v3/fetch_one_video",
        "method": "GET",
        "params": {"aweme_id": "${video_id}"},
        "adapter": "dy_video_detail_app",
        "_note": "v1.0 首选，返回完整视频信息含互动数据"
      },
      {
        "group": "web",
        "path": "/api/v1/douyin/web/fetch_video_detail",
        "method": "GET",
        "params": {"aweme_id": "${video_id}"},
        "adapter": "dy_video_detail_web",
        "_note": "v1.0 备选"
      }
    ],

    "fetch_video_comments": [
      {
        "group": "app",
        "path": "/api/v1/douyin/app/v3/fetch_video_comments",
        "method": "GET",
        "params": {"aweme_id": "${video_id}", "cursor": "${cursor}", "count": 20},
        "adapter": "dy_video_comments_app",
        "_note": "v1.0 首选"
      },
      {
        "group": "web",
        "path": "/api/v1/douyin/web/fetch_video_comments",
        "method": "GET",
        "params": {"aweme_id": "${video_id}", "cursor": "${cursor}", "count": 20},
        "adapter": "dy_video_comments_web",
        "_note": "v1.0 备选"
      }
    ],

    "fetch_hot_trend": [
      {
        "group": "index_app",
        "path": "/api/v1/douyin/app/v3/fetch_keyword_hot_trend",
        "method": "GET",
        "params": {"keyword": "${keyword}", "period": "${period}"},
        "adapter": "dy_hot_trend",
        "_note": "v1.0 关键词趋势（Index API），period: 7d/30d/90d"
      }
    ],

    "fetch_portrait": [
      {
        "group": "index_app",
        "path": "/api/v1/douyin/app/v3/fetch_keyword_portrait",
        "method": "GET",
        "params": {"keyword": "${keyword}"},
        "adapter": "dy_portrait",
        "_note": "v1.0 关键词受众画像分析"
      }
    ],

    "fetch_relation_word": [
      {
        "group": "index_app",
        "path": "/api/v1/douyin/app/v3/fetch_keyword_related_words",
        "method": "GET",
        "params": {"keyword": "${keyword}"},
        "adapter": "dy_relation_word",
        "_note": "v1.0 关键词相关词分析"
      }
    ],

    "fetch_hot_words": [
      {
        "group": "index_app",
        "path": "/api/v1/douyin/app/v3/fetch_hot_words",
        "method": "GET",
        "params": {"category": "${category}"},
        "adapter": "dy_hot_words",
        "_note": "v1.0 行业热词榜，category: beauty/food/tech 等"
      }
    ]

  }
}
